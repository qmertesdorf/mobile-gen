# Normalize line endings: store text as LF in the repo, check out native.
# Prevents core.autocrlf from rewriting committed files to CRLF on checkout
# (which broke the skills frontmatter test). Keep source/test/data files LF.
* text=auto eol=lf
# Generated raster masters are binary — never normalize line endings.
*.png binary
*.wav binary
*.ogg binary
