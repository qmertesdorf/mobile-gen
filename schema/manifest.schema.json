{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gameforge.local/manifest.schema.json",
  "title": "GameForge Title Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "created_at", "updated_at", "status", "concept", "build", "assets", "validation", "_reserved"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["concept", "generated", "validated", "playable", "styled", "scored", "failed"] },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "genre": { "type": "string" },
        "core_loop": { "type": "string" },
        "mechanics": { "type": "array", "items": { "type": "string" } },
        "art_direction": { "type": "string" },
        "target_platforms": { "type": "array", "items": { "type": "string" } },
        "differentiation_notes": { "type": "string" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engine": { "type": "string" },
        "engine_version": { "type": "string" },
        "language": { "type": "string" },
        "project_path": { "type": "string" },
        "addons": { "type": "array" },
        "export_presets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "name": { "type": "string" },
          "source": { "type": "string" },
          "origin": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "opens_in_editor": { "type": "boolean" },
        "runs": { "type": "boolean" },
        "core_loop_functional": { "type": "boolean" },
        "issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "asset_pass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string" },
        "visual_system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "palette": { "type": "array", "items": { "type": "string" } },
            "stroke": { "type": "string" },
            "form": { "type": "string" },
            "shading": { "type": "string" },
            "scale": { "type": "string" },
            "prompt_scaffold": { "type": "string" },
            "style": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "checkpoint": { "type": "string" },
                "loras": { "type": "array", "items": { "type": "string" } },
                "style_prompt": { "type": "string" }
              }
            }
          }
        },
        "reskinned": { "type": "array", "items": { "type": "string" } },
        "left_primitive": { "type": "array", "items": { "type": "string" } },
        "art_path": { "type": "string" },
        "notes": { "type": "string" },
        "recipes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "checkpoint": { "type": "string" },
              "prompt": { "type": "string" },
              "negative": { "type": "string" },
              "seed": { "type": "number" },
              "sampler": { "type": "string" },
              "steps": { "type": "number" },
              "cfg": { "type": "number" },
              "master_resolution": { "type": "number" },
              "layerdiffuse": { "type": "boolean" },
              "lora": { "type": "string" },
              "import_settings": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "mipmaps": { "type": "boolean" },
                  "filter": { "type": "string" },
                  "compression": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "audio_pass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string" },
        "audio_system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "mood_prompt": { "type": "string" },
            "style_descriptors": { "type": "array", "items": { "type": "string" } }
          }
        },
        "recipes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "kind": { "enum": ["sfx", "music"] },
              "prompt": { "type": "string" },
              "negative": { "type": "string" },
              "seed": { "type": "number" },
              "duration_s": { "type": "number" },
              "sampler": { "type": "string" },
              "steps": { "type": "number" },
              "cfg": { "type": "number" },
              "format": { "enum": ["wav", "ogg"] },
              "loop": { "type": "boolean" },
              "import_settings": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "loop": { "type": "boolean" },
                  "loop_offset": { "type": "number" }
                }
              }
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "event": { "type": "string" },
              "clip": { "type": "string" },
              "node": { "type": "string" },
              "signal": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "_reserved": {
      "type": "object",
      "properties": {
        "compliance": {},
        "store": {},
        "maintenance": {}
      }
    }
  }
}
