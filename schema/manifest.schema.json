{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gameforge.local/manifest.schema.json",
  "title": "GameForge Title Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "created_at", "updated_at", "status", "concept", "build", "assets", "validation", "_reserved"],
  "allOf": [
    {
      "$comment": "A polish status must carry the pass block it certifies. status is lossy (a game is styled OR scored, never both at once); these tie whichever terminal status is set to the block that proves it. asset/audio are orthogonal axes, so styled requires only asset_pass and scored only audio_pass — but packaged is the real ship gate and demands all three.",
      "if": { "properties": { "status": { "const": "styled" } }, "required": ["status"] },
      "then": { "required": ["asset_pass"] }
    },
    {
      "if": { "properties": { "status": { "const": "scored" } }, "required": ["status"] },
      "then": { "required": ["audio_pass"] }
    },
    {
      "if": { "properties": { "status": { "const": "packaged" } }, "required": ["status"] },
      "then": { "required": ["asset_pass", "audio_pass", "store_pass"] }
    }
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["concept", "generated", "validated", "playable", "styled", "scored", "packaged", "failed"] },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "genre": { "type": "string" },
        "core_loop": { "type": "string" },
        "mechanics": { "type": "array", "items": { "type": "string" } },
        "art_direction": { "type": "string" },
        "target_platforms": { "type": "array", "items": { "type": "string" } },
        "differentiation_notes": { "type": "string" },
        "theme": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "premise": { "type": "string" },
            "tone": { "type": "string" },
            "mood_keywords": { "type": "array", "items": { "type": "string" } },
            "setting": { "type": "string" }
          }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engine": { "type": "string" },
        "engine_version": { "type": "string" },
        "language": { "type": "string" },
        "project_path": { "type": "string" },
        "addons": { "type": "array" },
        "export_presets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "name": { "type": "string" },
          "source": { "type": "string" },
          "origin": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "opens_in_editor": { "type": "boolean" },
        "runs": { "type": "boolean" },
        "core_loop_functional": { "type": "boolean" },
        "issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "asset_pass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "enum": ["svg", "raster"] },
        "visual_system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "palette": { "type": "array", "items": { "type": "string" } },
            "stroke": { "type": "string" },
            "form": { "type": "string" },
            "shading": { "type": "string" },
            "scale": { "type": "string" },
            "prompt_scaffold": { "type": "string" },
            "world_bible": { "type": "string" },
            "style": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "checkpoint": { "type": "string" },
                "loras": { "type": "array", "items": { "type": "string" } },
                "style_prompt": { "type": "string" }
              }
            }
          }
        },
        "reskinned": { "type": "array", "items": { "type": "string" } },
        "left_primitive": { "type": "array", "items": { "type": "string" } },
        "art_path": { "type": "string" },
        "notes": { "type": "string" },
        "recipes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "checkpoint": { "type": "string" },
              "prompt": { "type": "string" },
              "negative": { "type": "string" },
              "seed": { "type": "number" },
              "sampler": { "type": "string" },
              "steps": { "type": "number" },
              "cfg": { "type": "number" },
              "master_resolution": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "layerdiffuse": { "type": "boolean" },
              "refine": { "type": "boolean" },
              "lora": { "type": "string" },
              "note": { "type": "string" },
              "import_settings": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "mipmaps": { "type": "boolean" },
                  "filter": { "type": "string" },
                  "compression": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "audio_pass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "enum": ["audio"] },
        "audio_system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "mood_prompt": { "type": "string" },
            "style_descriptors": { "type": "array", "items": { "type": "string" } },
            "sonic_character": { "type": "string" }
          }
        },
        "recipes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "kind": { "enum": ["sfx", "music"] },
              "prompt": { "type": "string" },
              "negative": { "type": "string" },
              "seed": { "type": "number" },
              "duration_s": { "type": "number" },
              "sampler": { "type": "string" },
              "steps": { "type": "number" },
              "cfg": { "type": "number" },
              "format": { "enum": ["wav", "ogg"] },
              "loop": { "type": "boolean" },
              "import_settings": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "loop": { "type": "boolean" },
                  "loop_offset": { "type": "number" }
                }
              }
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "event": { "type": "string" },
              "clip": { "type": "string" },
              "node": { "type": "string" },
              "signal": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "store_pass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icons": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "px": { "type": "number" },
              "kind": { "enum": ["launcher", "play", "adaptive_fg", "adaptive_bg"] },
              "source": { "type": "string" }
            }
          }
        },
        "splash": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string" },
            "show_image": { "type": "boolean" }
          }
        },
        "screenshots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "px": { "type": "string", "pattern": "^[0-9]+x[0-9]+$" },
              "source": { "type": "string" }
            }
          }
        },
        "atlas": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sheet": { "type": "string" },
            "map": { "type": "string" },
            "sprite_count": { "type": "number" }
          }
        },
        "size_budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total_bytes": { "type": "number" },
            "budget_bytes": { "type": "number" },
            "pass": { "type": "boolean" },
            "per_file": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "path": { "type": "string" },
                  "bytes": { "type": "number" }
                }
              }
            }
          }
        },
        "export_preset": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "platform": { "type": "string" },
            "package": { "type": "string" }
          }
        },
        "build_artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": { "enum": ["apk", "aab"] },
            "build_type": { "enum": ["debug", "release"] },
            "path": { "type": "string" },
            "bytes": { "type": "number" },
            "package": { "type": "string" }
          }
        },
        "icon_master": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "_reserved": {
      "type": "object",
      "properties": {
        "compliance": {},
        "store": {},
        "maintenance": {}
      }
    }
  }
}
